<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE configuration
  PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-config.dtd">
<configuration>
<typeAliases>
	<typeAlias alias="users" type="com.sample_pro.domain.Users"/>
	<typeAlias alias="Users" type="com.sample_pro.domain.Users"/>
	<typeAlias alias="permission" type="com.sample_pro.domain.Permission"/>
	<typeAlias alias="Permission" type="com.sample_pro.domain.Permission"/>
	<typeAlias alias="userMenu" type="com.sample_pro.domain.UserMenu"/>
	<typeAlias alias="UserMenu" type="com.sample_pro.domain.UserMenu"/>
	<typeAlias alias="userLog" type="com.sample_pro.domain.UserLog"/>
	<typeAlias alias="UserLog" type="com.sample_pro.domain.UserLog"/>
	<package name="com.sample_pro.domain"/>
</typeAliases>
  <mappers>
    <!-- master -->
    <mapper resource="mybatis/mapper/master/users.xml"/>
    <mapper resource="mybatis/mapper/master/PermMapper.xml"/>
    <!-- monitor -->
    <mapper resource="mybatis/mapper/monitor/TagMapper.xml"/>
    <mapper resource="mybatis/mapper/monitor/AlarmMapper.xml"/>
    <mapper resource="mybatis/mapper/monitor/TempMapper.xml"/>
    <mapper resource="mybatis/mapper/monitor/PlcConfigMapper.xml"/>
    <mapper resource="mybatis/mapper/monitor/NowWorkMapper.xml"/>
    <!-- facility -->
    <mapper resource="mybatis/mapper/facility/CalibMapper.xml"/>
    <mapper resource="mybatis/mapper/facility/InspectMapper.xml"/>
    <mapper resource="mybatis/mapper/facility/PartsMapper.xml"/>
    <mapper resource="mybatis/mapper/facility/ConsumableLedgerMapper.xml"/>
    <mapper resource="mybatis/mapper/facility/AuxiliaryInspectionMapper.xml"/>
    <!-- management -->
    <mapper resource="mybatis/mapper/management/EzInOutMapper.xml"/>
    <mapper resource="mybatis/mapper/management/EzInOutAttendMapper.xml"/>
  </mappers>
</configuration>
